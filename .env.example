# .env.example — copy to .env and fill in real values.
# .env is gitignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real credentials
#   docker compose up   (or podman compose up)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=neurons
POSTGRES_USERNAME=neuron
POSTGRES_PORT_EXPOSE=5432
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data

# ── Deployment target ─────────────────────────────────────────────────────────
SOURCE_DIRECTORY=local
CLOUD_PROVIDER=local

# ── AWS (leave as-is for local runs) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=your_default_region

# ── PulseAudio (Linux audio — set to match your system) ──────────────────────
PULSE_SERVER=unix:/run/user/1000/pulse/native
PULSE_SINK=alsa_output.pci-0000_01_00.1.hdmi-stereo
PULSE_SOURCE=alsa_input.usb-Generic_USB_Audio_201405280001-00.analog-stereo
PULSE_COOKIE=/root/.config/pulse/cookie

# ── Sensory server ────────────────────────────────────────────────────────────
SENSORY_SERVER_PORT=6667
SENSORY_SERVER_HOST=localhost
SENSORY_SERVER_URL=http://localhost:6667
SENSORY_SERVER_API_KEY=your_api_key
SENSORY_SERVER_API_SECRET=your_api_secret
SENSORY_SERVER_API_URL=http://localhost:6667/api
SENSORY_SERVER_API_VERSION=v1
SENSORY_SERVER_API_TIMEOUT=30
SENSORY_SERVER_API_RETRIES=3
SENSORY_SERVER_API_RETRY_DELAY=5
SENSORY_SERVER_API_MAX_RETRIES=5

# ── GitHub (used by container build scripts to pull private deps) ─────────────
REPO_URL=neuralmimicry/aarnn.git
GITHUB_USER=your_github_username
GITHUB_TOKEN=your_github_personal_access_token

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_TOKEN=notset
VAULT_ADDR=http://vault:8200
VAULT_API_ADDR=http://vault:8200
